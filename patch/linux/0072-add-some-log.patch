From 4ed6c70d0ce2920880888d919a90dbb07c8fa408 Mon Sep 17 00:00:00 2001
From: fashion <fashion@openbfdev.com>
Date: Sat, 4 Apr 2026 08:28:25 +0800
Subject: [PATCH] add some log

---
 arch/arm/configs/onecloud_defconfig           | 8 +-------
 drivers/gpu/drm/drm_ioctl.c                   | 2 ++
 drivers/gpu/drm/meson/meson_transwitch_hdmi.c | 5 +++++
 3 files changed, 8 insertions(+), 7 deletions(-)

diff --git a/arch/arm/configs/onecloud_defconfig b/arch/arm/configs/onecloud_defconfig
index a6b185adeb2b..c996082c7bac 100644
--- a/arch/arm/configs/onecloud_defconfig
+++ b/arch/arm/configs/onecloud_defconfig
@@ -1,4 +1,3 @@
-# Armbian defconfig generated with 6.12
 # CONFIG_LOCALVERSION_AUTO is not set
 CONFIG_SYSVIPC=y
 CONFIG_POSIX_MQUEUE=y
@@ -884,12 +883,6 @@ CONFIG_WL12XX=m
 CONFIG_WL18XX=m
 CONFIG_WLCORE_SPI=m
 CONFIG_WLCORE_SDIO=m
-CONFIG_RTL8723DS=m
-CONFIG_RTL8822BU=m
-CONFIG_RTL8821CU=m
-CONFIG_88XXAU=m
-CONFIG_RTL8192EU=m
-CONFIG_RTL8189ES=m
 CONFIG_ZD1211RW=m
 CONFIG_VIRT_WIFI=m
 CONFIG_NETDEVSIM=m
@@ -1664,6 +1657,7 @@ CONFIG_CRC4=m
 CONFIG_DMA_CMA=y
 CONFIG_CMA_SIZE_MBYTES=64
 CONFIG_PRINTK_TIME=y
+CONFIG_PRINTK_CALLER=y
 CONFIG_DEBUG_INFO_DWARF5=y
 CONFIG_DEBUG_INFO_BTF=y
 CONFIG_MAGIC_SYSRQ=y
diff --git a/drivers/gpu/drm/drm_ioctl.c b/drivers/gpu/drm/drm_ioctl.c
index 51f39912866f..324b009f35b1 100644
--- a/drivers/gpu/drm/drm_ioctl.c
+++ b/drivers/gpu/drm/drm_ioctl.c
@@ -784,6 +784,7 @@ long drm_ioctl(struct file *filp,
 	is_driver_ioctl = nr >= DRM_COMMAND_BASE && nr < DRM_COMMAND_END;
 
 	if (is_driver_ioctl) {
+		printk("is_driver_ioctl: %d", is_driver_ioctl);
 		/* driver ioctl */
 		unsigned int index = nr - DRM_COMMAND_BASE;
 
@@ -793,6 +794,7 @@ long drm_ioctl(struct file *filp,
 		ioctl = &dev->driver->ioctls[index];
 	} else {
 		/* core ioctl */
+		printk("core_driver_ioctl: %d", is_driver_ioctl);
 		if (nr >= DRM_CORE_IOCTL_COUNT)
 			goto err_i1;
 		nr = array_index_nospec(nr, DRM_CORE_IOCTL_COUNT);
diff --git a/drivers/gpu/drm/meson/meson_transwitch_hdmi.c b/drivers/gpu/drm/meson/meson_transwitch_hdmi.c
index 3a07ab76314e..407c8482fcd9 100644
--- a/drivers/gpu/drm/meson/meson_transwitch_hdmi.c
+++ b/drivers/gpu/drm/meson/meson_transwitch_hdmi.c
@@ -324,6 +324,7 @@ static void meson_txc_hdmi_config_serializer_clock(struct meson_txc_hdmi *priv,
 						   enum hdmi_colorimetry colorimetry)
 {
 	/* Serializer Internal clock setting */
+	printk("meson_txc_hdmi_config_serializer_clock");
 	if (colorimetry == HDMI_COLORIMETRY_ITU_601)
 		regmap_write(priv->regmap, TX_SYS1_PLL, 0x24);
 	else
@@ -347,6 +348,7 @@ static void meson_txc_hdmi_reconfig_packet_setting(struct meson_txc_hdmi *priv,
 	regmap_write(priv->regmap, TX_PACKET_CONTROL_2,
 		     TX_PACKET_CONTROL_2_HORIZONTAL_GC_PACKET_TRANSPORT_EN);
 
+	printk("meson_txc_hdmi_reconfig_packet_setting: cea_mode: %d", cea_mode);
 	switch (cea_mode) {
 	case 31:
 		/* 1920x1080p50 */
@@ -743,6 +745,7 @@ static void meson_txc_hdmi_bridge_atomic_enable(struct drm_bridge *bridge,
 	unsigned int i;
 	u8 cea_mode;
 
+	printk("meson_txc_hdmi_bridge_atomic_enable start");
 	bridge_state = drm_atomic_get_new_bridge_state(state, bridge);
 
 	connector = drm_atomic_get_new_connector_for_encoder(state,
@@ -764,6 +767,7 @@ static void meson_txc_hdmi_bridge_atomic_enable(struct drm_bridge *bridge,
 
 	cea_mode = drm_match_cea_mode(mode);
 
+
 	if (connector->display_info.is_hdmi) {
 		quant_range = drm_default_rgb_quant_range(mode);
 
@@ -955,6 +959,7 @@ static int meson_txc_hdmi_get_edid_block(void *data, u8 *buf, unsigned int block
 	regmap_update_bits(priv->regmap, TX_HDCP_EDID_CONFIG,
 			   TX_HDCP_EDID_CONFIG_SYS_TRIGGER_CONFIG, 0);
 
+	printk("regmap_read_poll_timeout: %d", ret);
 	if (ret)
 		return ret;
 
-- 
2.43.0

